; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="VEXAGON"
run/main_scene="res://main_scene.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

HexPathfinder="*res://hex_pathfinder.gd"
GameState="*res://GameState.gd"

[display]

window/size/viewport_width=5120
window/size/viewport_height=2160
window/size/resizable=false
window/stretch/mode="viewport"

[editor]

movie_writer/fps=144

[editor_plugins]

enabled=PackedStringArray("res://addons/ai_assistant_hub/plugin.cfg")

[plugins]

ai_assistant_hub/llm_api="openrouter_api"
ai_assistant_hub/preferences/thinking_target=0
ai_assistant_hub/preferences/skip_greeting=false
ai_assistant_hub/preferences/always_scroll_to_bottom=false

[rendering]

environment/defaults/default_clear_color=Color(0.249099, 0.380253, 0.777747, 1)
viewport/hdr_2d=true
2d/snap/snap_2d_transforms_to_pixel=true
